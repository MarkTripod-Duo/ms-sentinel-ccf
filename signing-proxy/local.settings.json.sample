{
  "IsEncrypted": false,
  "Values": {
    "AzureWebJobsStorage": "UseDevelopmentStorage=true",
    "FUNCTIONS_WORKER_RUNTIME": "python",
    "DUO_IKEY": "DIXXXXXXXXXXXXXXXXXX",
    "DUO_SKEY": "your-duo-admin-api-secret-key",
    "DUO_API_HOST": "api-XXXXXXXX.duosecurity.com"
  },
  "_comment": "Copy to local.settings.json for `func start`. NEVER commit real credentials. In Azure, DUO_SKEY is a Key Vault reference, not a literal."
}
